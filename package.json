{
  "name": "@adobecom/college",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Website foundation technology.",
  "scripts": {
    "test": "wtr \"./test/**/*.test.js\" --node-resolve --port=2000 --coverage",
    "test:watch": "npm test -- --watch",
    "test:nala": "playwright test",
    "test:nala:headed": "playwright test --headed",
    "test:nala:ui": "playwright test --ui",
    "test:nala:bstack": "playwright test --config browserstack.config.js",
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint 'blocks/**/*.css' 'styles/*.css'",
    "lint:js:fix": "eslint . --fix",
    "lint:js:nibble": "eslint-nibble .",
    "lint:css:fix": "stylelint 'blocks/**/*.css' 'styles/*.css' --fix",
    "lint:fix": "npm run lint:js:fix && npm run lint:css:fix",
    "prepare": "husky",
    "build:forms2": "node build/forms2/build-forms2.js",
    "build:sync-marketo": "node build/sync-marketo/sync-marketo.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobecom/college.git"
  },
  "author": "Adobe",
  "license": "Apache License 2.0",
  "bugs": {
    "url": "https://github.com/adobecom/college/issues"
  },
  "homepage": "https://github.com/adobecom/college#readme",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@esm-bundle/chai": "4.3.4-fix.0",
    "@playwright/test": "~1.59.0",
    "@web/dev-server-import-maps": "^0.2.1",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "browserstack-node-sdk": "^1.52.2",
    "chai": "^6.2.2",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-nibble": "^8.1.0",
    "eslint-plugin-chai-friendly": "^1.2.0",
    "eslint-plugin-compat": "^7.0.1",
    "eslint-plugin-ecmalist": "^1.0.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "microbundle": "^0.15.1",
    "sinon": "^21.1.2",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0"
  },
  "lint-staged": {
    "*.js": "eslint",
    "*.css": "stylelint"
  }
}
